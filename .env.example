OPENROUTER_API_KEY=
PLANNER_MODE=auto
# Verify model IDs in OpenRouter before running. Free models are supported but may rate-limit.
MODEL=<your-openrouter-model-id>
MODEL_FALLBACKS=<comma-separated-openrouter-model-ids>
PAID_FALLBACK_MODEL=<optional-paid-openrouter-model-id>
MODEL_VERIFIER=<optional-openrouter-model-id>
MAX_STEPS=25
START_URL=https://www.google.com
USE_LLM_RISK_CLASSIFIER=false

# --- Browser runtime ---
# BROWSER_MODE values:
#   chromium       (default) — Playwright bundled Chromium, profile dir .pw_profile
#   chrome_profile          — installed Google Chrome with a separate agent profile dir
BROWSER_MODE=chromium
# Used only when BROWSER_MODE=chrome_profile. Defaults to "chrome".
CHROME_CHANNEL=chrome
# Used only when BROWSER_MODE=chrome_profile. Must be a SEPARATE directory,
# never the user's default Google Chrome user data directory.
CHROME_USER_DATA_DIR=.chrome_agent_profile
# Optional: override the bundled-Chromium profile directory.
CHROMIUM_USER_DATA_DIR=.pw_profile
# Optional Playwright slow_mo in milliseconds (observability/stability, not stealth).
BROWSER_SLOW_MO_MS=0
# Optional random pre-action delay range in milliseconds. Both 0 disables pacing.
ACTION_MIN_DELAY_MS=0
ACTION_MAX_DELAY_MS=0

# --- Run logs ---
# Per-run logs are written under <RUN_LOG_ROOT>/<YYYY-MM-DD_HH-MM-SS>/
RUN_LOG_ROOT=logs/runs
